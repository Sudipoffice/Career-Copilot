# ─── General ───────────────────────────────────────────
NODE_ENV=development

# ─── Frontend ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Backend ───────────────────────────────────────────
PORT=4000
API_PREFIX=/api/v1

# ─── MongoDB ───────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/career-copilot
MONGODB_DB_NAME=career-copilot

# ─── Gemini AI ─────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Redis (optional) ──────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── AWS S3 (optional) ─────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=career-copilot-uploads

# ─── CORS ──────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
